@model OnlineDrinkShop.Models.Product
@{
    ViewData["Title"] = "Create";
}

<h2 class="text-info">Add New Product</h2>
<form asp-action="Create" enctype="multipart/form-data" method="post">
    <div class="p-4 rounded border">
        <div asp-validation-summary="ModelOnly" class="text-danger"> </div>
        <h3 class="text-danger">@ViewBag.message</h3>

        <div class="form-group row">
            <div class="col-2">
                <label asp-for="ProductName"></label>
            </div>
            <div class="col-5">
                <input asp-for="ProductName" class="form-control"/>
            </div>
            <span asp-validation-for="ProductName" class="text-danger"></span>
        </div>

        <div class="form-group row mt-2">
            <div class="col-2">
                <label asp-for="SmallPrice"></label>
            </div>
            <div class="col-5">
                <input asp-for="SmallPrice" class="form-control"/>
            </div>
            <span asp-validation-for="SmallPrice" class="text-danger"></span>
        </div>

        <div class="form-group row mt-2">
            <div class="col-2">
                <label asp-for="BigPrice"></label>
            </div>
            <div class="col-5">
                <input asp-for="BigPrice" class="form-control"/>
            </div>
            <span asp-validation-for="BigPrice" class="text-danger"></span>
        </div>

        <div class="form-group row mt-2">
            <div class="col-2">
                <label asp-for="Image"></label>
            </div>
            <div class="col-5">
                <input asp-for="Image" class="form-control" type="file" />
            </div>
            <span asp-validation-for="Image" class="text-danger"></span>
        </div>

        <div class="form-group row mt-2">
            <div class="col-2">
                <label asp-for="TagId"></label>
            </div>
            <div class="col-5">
                <select asp-for="TagId" asp-items="(SelectList)@ViewData["tagId"]" class="form-select"></select>
            </div>
            <span asp-validation-for="TagId" class="text-danger"></span>
        </div>

        <div class="form-group row mt-2">
            <div class="col-2">
                <label asp-for="Remark"></label>
            </div>
            <div class="col-5">
                <input asp-for="Remark" class="form-control"/>
            </div>
            @*<span asp-validation-for="Remark" class="text-danger"></span>*@
        </div>

        <div class="form-group row mt-2">
            <div class="col-2">
                <label asp-for="SugarLevelIsAvailable"></label>
            </div>
            <div class="col-5">
                <input asp-for="SugarLevelIsAvailable" class="" type="checkbox"/>
            </div>
            <span asp-validation-for="SugarLevelIsAvailable" class="text-danger"></span>
        </div>

        <div class="form-group row mt-2">
            <div class="col-2">
                <label asp-for="IceLevelIsAvailable"></label>
            </div>
            <div class="col-5">
                <input asp-for="IceLevelIsAvailable" class="" type="checkbox"/>
            </div>
            <span asp-validation-for="IceLevelIsAvailable" class="text-danger"></span>
        </div>

        <div class="form-group row mt-2">
            <div class="col-2">
                <label asp-for="IsAvailable"></label>
            </div>
            <div class="col-5">
                <input asp-for="IsAvailable" class="" type="checkbox"/>
            </div>
            <span asp-validation-for="IsAvailable" class="text-danger"></span>
        </div>

        <div class="form-group">
            <input type="submit" class="btn btn-primary" value="Save"/>
            <a asp-controller="Product" asp-action="Index" class="btn btn-success">Back To List</a>
        </div>
    </div>
</form>

@section Scripts{ 
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}