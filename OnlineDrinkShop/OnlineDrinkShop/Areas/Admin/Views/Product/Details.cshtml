@model OnlineDrinkShop.Models.Product
@{
    ViewData["Title"] = "Details";
}

<h2 class="text-info">Product Details</h2>
<form asp-action="Details" enctype="multipart/form-data" method="post">
    <div class="p-4 rounded border row">
        <div asp-validation-summary="ModelOnly" class="text-danger"> </div>

        <div class="col-8">
            <div class="form-group row">
                <div class="col-4">
                    <label asp-for="ProductName"></label>
                </div>
                <div class="col-8">
                    <input type="hidden" asp-for="Id"/>
                    <input asp-for="ProductName" class="form-control" readonly/>
                </div>
                <span asp-validation-for="ProductName" class="text-danger"></span>
            </div>

            <div class="form-group row mt-2">
                <div class="col-4">
                    <label asp-for="SmallPrice"></label>
                </div>
                <div class="col-8">
                    <input asp-for="SmallPrice" class="form-control" readonly/>
                </div>
                <span asp-validation-for="SmallPrice" class="text-danger"></span>
            </div>

            <div class="form-group row mt-2">
                <div class="col-4">
                    <label asp-for="BigPrice"></label>
                </div>
                <div class="col-8">
                    <input asp-for="BigPrice" class="form-control" readonly/>
                </div>
                <span asp-validation-for="BigPrice" class="text-danger"></span>
            </div>

            @*<div class="form-group row mt-2">
                <div class="col-4">
                    <label asp-for="Image"></label>
                </div>
                <div class="col-8">
                    <input asp-for="Image" class="form-control" type="file" />
                </div>
                <span asp-validation-for="Image" class="text-danger"></span>
            </div>*@

            <div class="form-group row mt-2">
                <div class="col-4">
                    <label asp-for="TagId"></label>
                </div>
                <div class="col-8">
                    <input asp-for="Tag.Tag_Name" class="form-control" readonly/>
                </div>
                <span asp-validation-for="TagId" class="text-danger"></span>
            </div>

            <div class="form-group row mt-2">
                <div class="col-4">
                    <label asp-for="Remark"></label>
                </div>
                <div class="col-8">
                    <input asp-for="Remark" class="form-control" readonly/>
                </div>
                @*<span asp-validation-for="Remark" class="text-danger"></span>*@
            </div>

            <div class="form-group row mt-2">
                <div class="col-4">
                    <label asp-for="SugarLevelIsAvailable"></label>
                </div>
                <div class="col-8">
                    <input asp-for="SugarLevelIsAvailable" class="" type="checkbox" disabled/>
                </div>
                <span asp-validation-for="SugarLevelIsAvailable" class="text-danger"></span>
            </div>

            <div class="form-group row mt-2">
                <div class="col-4">
                    <label asp-for="IceLevelIsAvailable"></label>
                </div>
                <div class="col-8">
                    <input asp-for="IceLevelIsAvailable" class="" type="checkbox" disabled/>
                </div>
                <span asp-validation-for="IceLevelIsAvailable" class="text-danger"></span>
            </div>

            <div class="form-group row mt-2">
                <div class="col-4">
                    <label asp-for="IsAvailable"></label>
                </div>
                <div class="col-8">
                    <input asp-for="IsAvailable" class="" type="checkbox" disabled/>
                </div>
                <span asp-validation-for="IsAvailable" class="text-danger"></span>
            </div>

            <div class="form-group">
                <a asp-controller="Product" asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Edit</a>
                <a asp-controller="Product" asp-action="Index" class="btn btn-success">Back To List</a>
            </div>
        </div>

        <div class="col-1">

        </div>

        <div class="col-3">
            <img src="~/@Model.Image" width="100%" style="border-radius: 5px; border: 1px solid #efefef"/>
        </div>
        
    </div>
</form>