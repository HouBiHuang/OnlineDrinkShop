@using OnlineDrinkShop.Models;
@using X.PagedList.Mvc.Core
@using X.PagedList.Web.Common
@model X.PagedList.IPagedList<Product>

@{
    ViewData["Title"] = "奶茶系列";
}

<br />
<br />

<div class="row">
    @foreach(var obj in Model)
    {
        <div class="col-sm-6 col-md-4 col-lg-3">
            <div class="card mb-4">
                <div class="card-header">
                    <h4 class="my-0 font-weight-normal">
                        <label style="font-size: 23px; color: steelblue">@obj.ProductName</label>
                    </h4>
                </div>
                <div class="card-body">
                    <img src="~/@obj.Image" alt="Card Image" class="card-img-top" style="height: 300px; object-fit: contain"/>
                </div>
                <div class="card-footer">
                    <div class="d-flex justify-content-between align-items-center">
                        <div class="btn-group">
                            <label style="font-size: 20px; color: #a51313"><b>小:$@obj.SmallPrice &nbsp;</b></label>
                            <label style="font-size: 20px; color: #a51313"><b>大:$@obj.BigPrice</b></label>
                        </div>
                        <a asp-controller="Home" asp-action="Details" asp-route-id="@obj.Id" class="btn btn-success pull-right">前往購物</a>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<div class="row">
    <div class="col-5">

    </div>
    <div class="col-2">
        @Html.PagedListPager(Model,
            c => Href("~/Customer/Home/MilkTea?page=" + c),
            new PagedListRenderOptions {
                LiElementClasses = new string[] { "page-item" },
                PageClasses = new string[] { "page-link" }
            })
    </div>
    <div class="col-5">

    </div>
</div>