@using OnlineDrinkShop.Models
@model List<Cart>
@{
    ViewData["Title"] = "Cart";
}

<h2 class="text-secondary">購物車</h2>

<div class="row">
    <table class="table table-bordered border-dark">
        <thead>
            <tr>
                <th>品項</th>
                <th>甜度</th>
                <th>冰度</th>
                <th>大小</th>
                <th>價格</th>
                <th>備註</th>
                <th>刪除</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.ProductName</td>
                    <td>@item.SugarLevel</td>
                    <td>@item.IceLevel</td>
                    <td>@item.Size</td>
                    <td>@item.Price</td>
                    <td>@item.Remark</td>
                    <td>
                        <a asp-controller="Home" asp-action="Remove" asp-route-id="@item.Id" class="btn btn-danger">
                            <i class="bi bi-trash-fill"></i>
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
<div class="row">
    <div class="col-4 text-start">
        @*<a asp-controller="Home" asp-action="Index" class="btn btn-success">Back to Home</a>*@
    </div>
    <div class="col-4 text-center">
        <h3>總金額:@Model.Sum(c => c.Price)元</h3>
    </div>
    <div class="col-4 text-end">
        <a asp-area="Customer" asp-controller="Order" asp-action="Checkout" class="btn btn-info">結帳去!</a>
    </div>
</div>